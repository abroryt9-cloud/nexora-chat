# Server Configuration
PORT=5000
NODE_ENV=production

# Database
# Для MongoDB Atlas (production):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nexora?retryWrites=true&w=majority
# Для локальной MongoDB:
# MONGODB_URI=mongodb://localhost:27017/nexora

# Redis (опционально)
# REDIS_URL=redis://localhost:6379

# JWT Secrets (ОБЯЗАТЕЛЬНО измените для production!)
JWT_SECRET=change_this_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
ENCRYPTION_KEY=change_this_encryption_key_in_production

# API Keys
COINGECKO_API_KEY=your_coingecko_key
TENOR_API_KEY=your_tenor_key
DEEPSEEK_API_KEY=your_deepseek_key
GEMINI_API_KEY=your_gemini_key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# CORS (URL клиента)
# Для Render:
CLIENT_URL=https://nexora-client.onrender.com
# Для локальной разработки:
# CLIENT_URL=http://localhost:5173
