# Production Environment Variables for Render
NODE_ENV=production
PORT=5000

# Database - will be set by Render
# MONGODB_URI=<from Render environment>

# JWT Secrets - will be generated by Render
# JWT_SECRET=<generated by Render>
# JWT_REFRESH_SECRET=<generated by Render>
# ENCRYPTION_KEY=<generated by Render>

# CORS
CLIENT_URL=https://nexora-client.onrender.com

# Optional API Keys (set manually in Render dashboard if needed)
# COINGECKO_API_KEY=
# TENOR_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Email (set manually if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=