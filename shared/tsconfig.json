{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["types/**/*", "constants/**/*", "utils/**/*"],
  "exclude": ["node_modules", "dist"]
}
